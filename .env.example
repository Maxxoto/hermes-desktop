# ============================================================
# Hermes Desktop — Code Signing & Notarization
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file.

# Developer ID Application certificate (exported as base64 .p12)
# Export with: openssl base64 -in certificate.p12 -out cert_base64.txt
APPLE_CERTIFICATE=

# Password for the .p12 certificate
APPLE_CERTIFICATE_PASSWORD=

# Signing identity name (matches Keychain Access "Common Name")
# Example: "Developer ID Application: Ahmat Dani (ABCD1234EF)"
APPLE_SIGNING_IDENTITY=

# ============================================================
# Notarization (App Store Connect API / Apple ID)
# ============================================================

# Apple ID email address test
APPLE_ID=

# App-specific password (generate at appleid.apple.com)
APPLE_PASSWORD=

# Apple Team ID (found in Developer Portal > Membership)
APPLE_TEAM_ID=
